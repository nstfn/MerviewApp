 /**
+ * Toggle preview panel fullscreen mode.
+ * Hides the editor panel and resize handle, letting the preview expand
+ * to full width with comfortable reading margins (max-width: 800px).
+ */
+function togglePreviewFullscreen() {
+    const container = document.querySelector('.container');
+    if (!container) return;
+    const isFullscreen = container.classList.toggle('preview-fullscreen');
+    const btn = document.getElementById('previewFullscreenBtn');
+    if (btn) {
+        btn.title = isFullscreen
+            ? 'Exit fullscreen preview (Esc)'
+            : 'Toggle fullscreen preview (Shift+Cmd+F)';
+    }
+}
